<mujoco model="rrbot_arm">
  <asset>
    <texture name="skybox" type="skybox" builtin="gradient" rgb1=".2 .3 .4" rgb2="0 0 0" width="800" height="800" mark="random" markrgb="1 1 1" />
    <texture name="grid" type="2d" builtin="checker" rgb1=".2 .1 .2" rgb2=".3 .2 .3" width="300" height="300" mark="edge" markrgb=".3 .2 .3" />
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance=".2" />
    <material name="self" rgba=".7 .5 .3 1" />
    <material name="plain_white" rgba="1 1 1 1" specular="0" shininess="0" />
  </asset>
  <visual>
    <headlight ambient=".4 .4 .4" diffuse=".8 .8 .8" specular="0 0 0" />
    <map znear=".001" />
    <quality shadowsize="16384" />
  </visual>
  <compiler angle="degree" />
  <option integrator="RK4" timestep="0.01" />
  <default>
    <joint armature="1" damping="1" limited="true" />
    <geom conaffinity="0" condim="3" density="5.0" friction="1.0 0.5 0.5" margin="0.01" rgba=".7 .5 .3 1" />
  </default>
  <worldbody>
    <light cutoff="100" diffuse="1 1 1" dir="0.3 0 -1.3" directional="true" exponent="1" pos="-30 0 130" specular=".1 .1 .1" />
    <geom conaffinity="1" condim="3" name="floor" pos="0 0 0" rgba="1 1 1 1" size="200 200 .125" type="plane" material="grid" />
    <!-- 2-joint serial arm (rrbot derived, scale 1/8).
         Joints rotate about Z-axis → arm sweeps in XY plane for horizontal pushing.
         bone_offset type=xy: optimizer changes (x,y) of each link endpoint.
         Total reach: default 0.55m, max (with bone_offset ub=+0.5) 1.55m.
         Cube face at x=0.85m → arm CANNOT reach without morphology optimization.
         Base at z=0.15: sphere (r=0.1) bottom at z=0.05, avoids floor penetration in Choreonoid.
         Arm and cube both at z=0.15 → horizontal pushing geometry aligned. -->
    <body name="0" pos="0 0 0.15">
      <camera name="track" mode="trackcom" pos="0 -3 0.3" xyaxes="1 0 0 0 0 1" />
      <geom pos="0 0 0" size="0.1" type="sphere" />
      <!-- no free joint: base is fixed to world -->
      <!-- shoulder: connects base to upper arm -->
      <body name="1" pos="0 0 0">
        <joint axis="0 0 1" name="1_joint" pos="0 0 0" range="-180 180" type="hinge" velocity="3.0" />
        <geom fromto="0 0 0 0.3 0 0" size="0.05" type="capsule" />
        <!-- elbow: connects upper arm to forearm; pos is endpoint of upper arm geom -->
        <!-- body name "11" = xml_robot.py reindex: 1st child(ind=1) of body "1" → str(1)+"1" = "11" -->
        <body name="11" pos="0.3 0 0">
          <joint axis="0 0 1" name="11_joint" pos="0 0 0" range="-180 180" type="hinge" velocity="3.0" />
          <geom fromto="0 0 0 0.25 0 0" size="0.04" type="capsule" />
        </body>
      </body>
    </body>
    <!-- cube: size 0.5 (1.0m side, 元論文のPusherに準拠), 左面 x = 1.0 - 0.5 = 0.5m
         density=2.7 → mass=2.7kg (元の0.3m cube と同じ質量、大きくなっても重さを維持)
         アームの先端 (x≈0.3-0.4m) から左面 (x=0.5m) まで 0.1-0.2m 程度。
         大きいcubeは「どこに当たっても押せる」→精密な接触不要→bat tacticが成立しやすい。 -->
    <body name="cube" pos="1.0 0 0.20">
      <joint name="cube_slide" type="slide" axis="1 0 0" damping="10.0" range="-2 200" />
      <joint name="cube_slide2" type="slide" axis="0 1 0" damping="10.0" range="-100 100" />
      <geom name="cube_geom" type="box" size="0.5 0.5 0.5" rgba="0.8 0.2 0.2 1.0" friction="0.5 0.1 0.1" density="2.7" contype="1" conaffinity="1" />
    </body>
  </worldbody>
  <actuator>
    <motor ctrllimited="true" ctrlrange="-1.0 1.0" joint="1_joint" gear="150" name="1_joint" />
    <motor ctrllimited="true" ctrlrange="-1.0 1.0" joint="11_joint" gear="100" name="11_joint" />
  </actuator>
</mujoco>
